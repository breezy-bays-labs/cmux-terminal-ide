# shellcheck shell=sh disable=SC2034
# profiles/base.env — shared MACHINE-PROFILE defaults (AXIS 1 = config regime).
# Each profile sources this first, then overrides only what differs. Sourced by
# lib/common.sh (which has already set $DBT_WS_HOME).
#
# This file owns AXIS 1 (machine profile = config regime) ONLY. The data/policy
# axis (warehouse, harlequin, profiles dir) is resolved separately in
# lib/common.sh and is INDEPENDENT of which machine profile is active — a profile
# NEVER sets WAREHOUSE/HARLEQUIN. Defaults here are the clean `bare` baseline.

SHELL_KIND="zsh"            # nu | zsh   — login shell of the workspace
CONFIG_REGIME="bundled"     # bundled | xdg-stow — config source for this machine
PROMPT_GLYPH=""             # prompt marker for cmux readiness polling (profile sets)
YAZI_CONFIG_VARIANT="bare"  # which config/yazi/<variant> dir to use

DBT_WS_BIN="$DBT_WS_HOME/bin"
DBT_WS_XDG="$DBT_WS_HOME/config"
