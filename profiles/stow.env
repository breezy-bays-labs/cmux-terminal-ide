# shellcheck shell=sh disable=SC2034
# profiles/stow.env — the maintainer's box: nushell · XDG + GNU Stow dotfiles.
# Complements the user's ~/.config (read-only; never clobbered).
#
# AXIS 1 (config regime) ONLY. Whether the warehouse/harlequin are active is the
# INDEPENDENT data/policy axis — a `stow` machine can run any data axis, and this
# profile sets none of it. The path hints below are machine-local fallbacks for
# dbt_dir()/duckdb_path(); the per-workspace state file (and S2's warehouse
# auto-derive) override them.

# shellcheck source=/dev/null
. "$DBT_WS_HOME/profiles/base.env"

SHELL_KIND="nu"
CONFIG_REGIME="xdg-stow"
PROMPT_GLYPH="❯"
YAZI_CONFIG_VARIANT="stow"

# Machine-local default paths (a per-workspace state file overrides these).
DBT_WS_DBT_DIR_DEFAULT="$HOME/github/dbt-playground/dbt_project"
DBT_WS_DUCKDB_DEFAULT="$HOME/github/dbt-playground/dbt_project/dev.duckdb"
DBT_WS_YAZI_ID_DEFAULT="1717"
