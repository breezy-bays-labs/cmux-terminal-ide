# shellcheck shell=sh disable=SC2034
# profiles/bare.env — the clean distributable (team default, clean MacBook). No
# dotfiles dependency: ships the bundled config under config/.
#
# AXIS 1 (config regime) ONLY. This profile says NOTHING about the warehouse or
# harlequin — that is the independent data/policy axis (resolved in
# lib/common.sh). The structural absence of the warehouse-query surface on a
# `bare` machine is enforced by install.sh (it omits the hq-preview symlink), not
# by this file.

# shellcheck source=/dev/null
. "$DBT_WS_HOME/profiles/base.env"

SHELL_KIND="zsh"
CONFIG_REGIME="bundled"
PROMPT_GLYPH="%"
YAZI_CONFIG_VARIANT="bare"
