#!/bin/sh
# git-glance-render <repo> — render one working-tree status frame (short status + stash count).
REPO="${1:-$PWD}"
cd "$REPO" 2>/dev/null || exit 0
printf '\033[1;34m git · %s\033[0m\n\n' "$(basename "$REPO")"
git -c color.status=always status -sb 2>/dev/null
printf '\n\033[2m stash: %s\033[0m\n' "$(git stash list 2>/dev/null | wc -l | tr -d ' ')"
